generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  FOREMAN
  ADMIN
  DIRECTOR
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

enum DayValue {
  FULL
  THREE_QUARTERS
  HALF
  QUARTER
  ABSENT
  SICK
}

model User {
  id           String   @id @default(cuid())
  login        String   @unique
  passwordHash String
  fullName     String
  role         Role
  objectId     String?
  object       Object?  @relation(fields: [objectId], references: [id])
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  createdTimesheets  Timesheet[]  @relation("TimesheetCreatedBy")
  approvedTimesheets Timesheet[]  @relation("TimesheetApprovedBy")
  positions          Position[]   @relation("ForemanPositions")
  departments        Department[] @relation("ForemanDepartments")
  employees          Employee[]   @relation("ForemanEmployees")

  @@index([objectId])
}

model Position {
  id     String @id @default(cuid())
  name   String
  userId String
  user   User   @relation("ForemanPositions", fields: [userId], references: [id])

  employees Employee[]

  @@unique([name, userId])
  @@index([userId])
}

model Object {
  id       String  @id @default(cuid())
  name     String  @unique
  isActive Boolean @default(true)

  foremen       User[]
  timesheets    Timesheet[]
  timesheetRows TimesheetRow[]
}

model Department {
  id       String  @id @default(cuid())
  name     String
  userId   String
  user     User    @relation("ForemanDepartments", fields: [userId], references: [id])
  isActive Boolean @default(true)

  employees Employee[]

  @@unique([name, userId])
  @@index([userId])
}

model Employee {
  id               String     @id @default(cuid())
  fullName         String
  positionId       String
  position         Position   @relation(fields: [positionId], references: [id])
  departmentId     String
  department       Department @relation(fields: [departmentId], references: [id])
  defaultShiftRate Decimal    @db.Decimal(10, 2)
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  foremanId        String
  foreman          User       @relation("ForemanEmployees", fields: [foremanId], references: [id])

  timesheetRows TimesheetRow[]

  @@index([positionId])
  @@index([departmentId])
  @@index([fullName])
  @@index([foremanId])
}

model Timesheet {
  id                  String          @id @default(cuid())
  objectId            String
  object              Object          @relation(fields: [objectId], references: [id])
  year                Int             @db.SmallInt
  month               Int             @db.SmallInt
  status              TimesheetStatus @default(DRAFT)
  createdByUserId     String
  createdBy           User            @relation("TimesheetCreatedBy", fields: [createdByUserId], references: [id])
  submittedAt         DateTime?
  approvedAt          DateTime?
  approvedByUserId    String?
  approvedBy          User?           @relation("TimesheetApprovedBy", fields: [approvedByUserId], references: [id])
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  rows TimesheetRow[]

  @@unique([objectId, createdByUserId, year, month])
  @@index([year, month])
  @@index([status])
}

model TimesheetRow {
  id                   String    @id @default(cuid())
  timesheetId          String
  timesheet            Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  employeeId           String
  employee             Employee  @relation(fields: [employeeId], references: [id])
  positionSnapshot     String
  departmentSnapshot   String
  shiftRateSnapshot    Decimal   @db.Decimal(10, 2)
  objectId             String
  object               Object    @relation(fields: [objectId], references: [id])
  notes                String?
  paidAmount           Decimal   @default(0) @db.Decimal(10, 2)

  days TimesheetDay[]

  @@unique([timesheetId, employeeId])
  @@index([employeeId])
  @@index([objectId])
}

model TimesheetDay {
  id              String       @id @default(cuid())
  timesheetRowId  String
  row             TimesheetRow @relation(fields: [timesheetRowId], references: [id], onDelete: Cascade)
  day             Int          @db.SmallInt
  value           DayValue

  @@unique([timesheetRowId, day])
}

model Backup {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  label       String?
  filename    String   @unique
  sizeBytes   Int
  isAutomatic Boolean  @default(false)

  @@map("backups")
}
