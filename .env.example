# Postgres connection — values match docker-compose.yml for local dev.
DATABASE_URL="postgresql://tabel:tabel@localhost:5432/tabel?schema=public"

# NextAuth — generate a secret with: openssl rand -base64 32
# Do NOT set NEXTAUTH_URL in dev — NextAuth v5 auto-detects host from request headers
# NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""
AUTH_TRUST_HOST=true

# Daily backup cron — generate with: openssl rand -base64 32
CRON_SECRET=""

# Backup storage directory (default: <cwd>/backups, use /data/backups in Docker)
# BACKUP_DIR="/data/backups"
